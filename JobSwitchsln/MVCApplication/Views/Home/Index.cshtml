@model MVCApplication.Models.InterviewEntryViewModel

@{
    ViewData["Title"] = "Interview Tracker";
}

<h2 class="mb-4">Interview Tracker</h2>

<form asp-action="Index" method="post" class="mb-5">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="CompanyName" class="form-label"></label>
            <input asp-for="CompanyName" class="form-control" />
            <span asp-validation-for="CompanyName" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Website" class="form-label"></label>
            <input asp-for="Website" class="form-control" />
        </div>

        <div class="col-md-4">
            <label asp-for="Industry" class="form-label"></label>
            <input asp-for="Industry" class="form-control" />
        </div>

        <div class="col-md-4">
            <label asp-for="RoleTitle" class="form-label"></label>
            <input asp-for="RoleTitle" class="form-control" />
            <span asp-validation-for="RoleTitle" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="AppliedDate" class="form-label"></label>
            <input asp-for="AppliedDate" type="date" class="form-control" />
            <span asp-validation-for="AppliedDate" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" class="form-select">
                <option value="Applied">Applied</option>
                <option value="Interviewing">Interviewing</option>
                <option value="Selected">Selected</option>
                <option value="Rejected">Rejected</option>
                <option value="On Hold">On Hold</option>
            </select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="JobLink" class="form-label"></label>
            <input asp-for="JobLink" class="form-control" />
        </div>

        <div class="col-md-4">
            <label asp-for="SalaryExpectation" class="form-label"></label>
            <input asp-for="SalaryExpectation" class="form-control" />
        </div>

        <div class="col-12">
            <label asp-for="Notes" class="form-label"></label>
            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
        </div>

        <div class="col-12">
            <button type="submit" class="btn btn-primary">Save Interview</button>
        </div>
    </div>
</form>

<h4 class="mb-3">Interviews Given So Far</h4>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Company</th>
            <th>Role</th>
            <th>Applied Date</th>
            <th>Status</th>
            <th>Job Link</th>
            <th>Notes</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.Applications.Any())
        {
            foreach (var item in Model.Applications)
            {
                <tr>
                    <td>@item.Company.Name</td>
                    <td>@item.RoleTitle</td>
                    <td>@item.AppliedDate.ToString("dd-MMM-yyyy")</td>
                    @* <td>@item.Status</td> *@

                    <td>
                        <form asp-action="UpdateStatus" method="post" class="d-flex gap-2">
                            <input type="hidden" name="id" value="@item.Id"/>

                            <select name="status" class="form-select form-select-sm">

                                <option value ="Applied" selected="@(item.Status == "Applied")">Applied</option>
                                <option value="Interviewing" selected="@(item.Status == "Interviewing")">Interviewing</option>
                                <option value="Selected" selected="@(item.Status == "Selected")">Selected</option>
                                <option value="Rejected" selected="@(item.Status == "Rejected")">Rejected</option>
                                <option value="On Hold" selected="@(item.Status == "On Hold")">On Hold</option>

                            </select>

                            <button type="submit" class="btn btn-sm btn-outline-primary">Update</button>

                        </form>
                    </td>



                    <td>
                        @if (!string.IsNullOrWhiteSpace(item.JobLink))
                        {
                            <a href="@item.JobLink" target="_blank">Open</a>
                        }
                    </td>
                    <td>@item.Notes</td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center">No interviews added yet.</td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}